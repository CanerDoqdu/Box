# Bearer token required for dashboard mutation endpoints (POST /api/force-rebase,
# /api/daemon-start, /api/daemon-stop). If not set, mutations are hard-blocked (403).
# Generate a secure value with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BOX_DASHBOARD_TOKEN=<your-secure-token-here>

COPILOT_CLI_COMMAND=copilot
