{
  "extends": "markdownlint/style/relaxed",
  "no-hard-tabs": false,
  "line-length": {
    "line_length": 200,
    "heading_line_length": 200,
    "headers": false,
    "code_blocks": false,
    "code_fence": false,
    "tables": false
  },
  "no-inline-html": false,
  "no-bare-urls": false,
  "no-space-in-code": false,
  "blanks-around-headings": false,
  "blanks-around-lists": false,
  "list-item-indent": {
    "indent": 2
  },
  "hr-style": {
    "style": "---"
  },
  "code-block-style": {
    "style": "fenced"
  }
}
